                  <Rectangle arcHeight="15.0" arcWidth="15.0" fill="DODGERBLUE" height="120.0" stroke="BLACK" strokeType="INSIDE" width="120.0" />
                  <VBox prefHeight="82.0" prefWidth="317.0">
                     <children>
                        <Label fx:id="lbl_audioName" prefHeight="40.0" prefWidth="316.0" textFill="WHITE">
