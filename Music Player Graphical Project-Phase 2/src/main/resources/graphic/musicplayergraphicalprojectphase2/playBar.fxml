<AnchorPane prefHeight="132.0" prefWidth="1150.0" style="-fx-background-color: black;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.PlayBarController">
   <children>
      <HBox alignment="CENTER_LEFT" layoutX="5.0" prefHeight="156.0" prefWidth="1150.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
